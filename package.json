{
  "name": "openfolio",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,client -c blue,green \"npm run dev -w backend\" \"npm run dev -w client\"",
    "build": "npm run build -w backend && npm run build -w client",
    "build:backend": "npm run build -w backend",
    "build:client": "npm run build -w client",
    "start": "npm run build && npm run start -w backend",
    "start:backend": "npm run start -w backend",
    "import:history": "npm run import:history -w backend --",
    "migrate:mongo": "npm run migrate:mongo -w backend",
    "migrate:to-atlas": "npm run migrate:to-atlas -w backend",
    "backup:mongo": "npm run backup:from-atlas -w backend",
    "backup:from-atlas": "npm run backup:from-atlas -w backend",
    "backup:mirror-local": "npm run backup:mirror-local -w backend",
    "sync:atlas": "npm run sync:atlas -w backend",
    "sync:atlas:pull": "npm run sync:atlas:pull -w backend",
    "verify:atlas": "npm run verify:atlas -w backend"
  },
  "workspaces": [
    "backend",
    "client"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
