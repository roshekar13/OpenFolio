# Copy to backend/atlas-credentials.env (gitignored) or set MONGO_URI in backend/.env.
# Atlas is the primary database for local dev, Render, and GitHub Pages.

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
OPENFOLIO_MONGO_DB=openfolio

# Optional: local Mongo mirror for offline backup only (not used at runtime unless ALLOW_LOCAL).
# OPENFOLIO_LOCAL_MONGO_URI=mongodb://localhost:27017
