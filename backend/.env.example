# Copy to backend/.env and fill in values. Do not commit .env.

# Cross-site auth: GitHub Pages + local Vite dev server.
# No trailing paths on origins.
CLIENT_ORIGINS=https://rorocantcode.github.io,http://localhost:5000

# Long random string for express-session (change before any public deployment).
SESSION_SECRET=

# Google Gemini (Advanced Analytics)
GEMINI_API_KEY=

# Set true when behind Render/Railway; optional for local API testing.
TRUST_PROXY=true

# --- Primary database (Atlas) ---
# Runtime (local backend + Render) reads/writes Atlas only.
# Copy atlas-credentials.env.example → atlas-credentials.env, or set here:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# OPENFOLIO_MONGO_DB=openfolio
#
# Atlas → Network Access: allow 0.0.0.0/0 for Render (no quotes in dashboard values).
#
# --- Local backup mirror (optional) ---
# OPENFOLIO_LOCAL_MONGO_URI=mongodb://localhost:27017
# Refresh mirror from Atlas: npm run backup:mirror-local
# JSON backup from Atlas:     npm run backup:from-atlas
#
# Legacy local-only dev without Atlas (not recommended):
# OPENFOLIO_ALLOW_LOCAL_MONGO=true
